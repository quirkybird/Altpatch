{
  "name": "@packages/altpatch-api",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm --filter @packages/server-core build && pnpm run build"
  },
  "dependencies": {
    "@packages/server-core": "workspace:^0.1.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.12",
    "vite": "^6.0.0",
    "ws": "^8.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
