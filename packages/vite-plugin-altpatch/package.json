{
  "name": "@quirkybird/vite-plugin-altpatch",
  "version": "0.1.19",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime-entry": {
      "import": "./dist/runtime-entry.js"
    }
  },
  "files": [
