    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@locator/babel-jsx": "^0.5.1",
    "diff": "^5.2.0",
    "express": "^4.21.2",
    "prismjs": "^1.30.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "vite": ">=6.0.0-0 <9"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "rollup": "^4.59.0",
    "vite": "^6.0.0"
  },
  "publishConfig": {
