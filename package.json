{
  "name": "altpatch-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "pnpm run clean:src-artifacts && turbo run build && pnpm run check:src-artifacts",
    "check:src-artifacts": "node scripts/src-artifacts.cjs check",
    "clean:src-artifacts": "node scripts/src-artifacts.cjs clean",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
